{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Caching": {
    "UsersListExpirationMinutes": 15
  },
  "ExternalApis": {
    "QuoteApiBaseUrl": "https://api.quotable.io"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  }
}
