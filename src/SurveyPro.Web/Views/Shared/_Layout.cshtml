<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SurveyPro.Web</title>
    
    <link rel="stylesheet" href="~/css/site.min.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5/dist/quartz/bootstrap.min.css" rel="stylesheet">
    
    @RenderSection("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">SurveyPro.Web</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" 
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Surveys" asp-action="Index">Surveys</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>

                        @if (User.IsInRole("Author"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Surveys" asp-action="My">My surveys</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Surveys" asp-action="Create">Create survey</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminUsers" asp-action="Index">Users</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="AdminSurveys" asp-action="Index">All Surveys</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown" id="notifications-shell" 
                                data-notifications-url="@Url.Action("Recent", "Notifications")">
                                <button class="nav-link btn btn-link text-white position-relative dropdown-toggle"
                                        type="button" id="notificationsDropdown"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    Notifications
                                    <span id="notification-count" 
                                          class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                                </button>
                                  <div class="dropdown-menu dropdown-menu-end shadow p-0 notifications-menu" 
                                      aria-labelledby="notificationsDropdown">
                                    <div class="px-3 py-2 border-bottom small text-uppercase text-muted">Recent activity</div>
                                    <div id="notification-menu-items" class="list-group list-group-flush"></div>
                                </div>
                            </li>
                        }

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Profile">Profile</a>
                            </li>
                            <li class="nav-item">
                                <button class="nav-link btn btn-link fw-bold"
                                        data-bs-toggle="modal" data-bs-target="#logoutModal">
                                    Logout
                                </button>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container flex-grow-1">
        <main role="main" class="pb-5 mt-4">
            @RenderBody()
        </main>
    </div>

    <div id="notification-toast-container" class="toast-container position-fixed top-0 end-0 p-3 notification-toast-layer"></div>

    <footer class="border-top text-center py-3 mt-auto">
        <div class="container">
            &copy; 2026 - SurveyPro.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <div class="modal fade" id="logoutModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Logout</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to logout?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form asp-controller="Account" asp-action="LogoutConfirmed" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-danger">Yes, Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js" 
            crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="~/js/site.min.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>