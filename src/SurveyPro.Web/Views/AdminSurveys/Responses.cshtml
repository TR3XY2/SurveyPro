@model SurveyPro.Application.DTOs.Surveys.AdminSurveyResponsesDto
@{
    ViewData["Title"] = "Survey Responses";
}

<section class="admin-users-hero mb-4">
    <div class="admin-users-hero__overlay"></div>
    <div class="admin-users-hero__content">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h1 class="display-5 fw-bold mb-2">@Model.SurveyTitle</h1>
                <p class="lead mb-0">Participant responses for this survey.</p>
            </div>
            <div class="text-end">
                <div class="small text-uppercase opacity-75">Participants</div>
                <span class="badge text-bg-primary fs-6">@Model.TotalParticipants</span>
            </div>
        </div>
    </div>
</section>

<section class="card border-0 shadow-lg admin-users-card">
    <div class="card-body">
        @if (!Model.Participants.Any())
        {
            <div class="alert alert-info mb-0">No submitted responses yet.</div>
        }
        else
        {
            <div class="accordion" id="adminResponsesAccordion">
                @for (var i = 0; i < Model.Participants.Count; i++)
                {
                    var participant = Model.Participants[i];
                    var headingId = $"admin-r-heading-{i}";
                    var collapseId = $"admin-r-collapse-{i}";

                    <div class="accordion-item mb-2 border rounded-3 overflow-hidden">
                        <h2 class="accordion-header" id="@headingId">
                            <button class="accordion-button @(i == 0 ? string.Empty : "collapsed")"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="@(i == 0 ? "true" : "false")"
                                    aria-controls="@collapseId">
                               <div class="d-flex justify-content-between align-items-center w-100">

                                <!-- ІМ'Я -->
                                <span class="fw-semibold fs-5 text-white">
                                    @participant.ParticipantName
                                </span>
                            
                                <!-- ПРАВО -->
                                <div class="d-flex align-items-center gap-3">
                            
                                    <span class="badge bg-light text-dark px-3 py-2">
                                        @participant.SubmittedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                    </span>
                            
                                    <form asp-action="DeleteResponse" asp-controller="AdminSurveys" method="post" class="m-0">
                                        <input type="hidden" name="participantId" value="@participant.ParticipantId" />
                                        <input type="hidden" name="surveyId" value="@Model.SurveyId" />
                            
                                        <button type="submit"
                                                class="btn btn-sm btn-danger px-3"
                                                onclick="return confirm('Delete this response?');">
                                            Delete
                                        </button>
                                    </form>
                            
                                </div>
                            </div>
                            </button>
                        </h2>

                        <div id="@collapseId"
                             class="accordion-collapse collapse @(i == 0 ? "show" : string.Empty)"
                             aria-labelledby="@headingId"
                             data-bs-parent="#adminResponsesAccordion">
                            <div class="accordion-body">
                                @if (!participant.Answers.Any())
                                {
                                    <div class="text-muted">No answers in this submission.</div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm align-middle mb-0">
                                            <thead>
                                                <tr>
                                                    <th style="width: 45%;">Question</th>
                                                    <th style="width: 15%;">Type</th>
                                                    <th style="width: 40%;">Answer</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var answer in participant.Answers)
                                                {
                                                    <tr>
                                                        <td class="fw-semibold">@answer.QuestionText</td>
                                                        <td><span class="badge text-bg-secondary">@answer.QuestionType</span></td>
                                                        <td>@answer.Answer</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

<div class="mt-3 d-flex gap-2 flex-wrap">
    <a asp-action="Questions" asp-route-id="@Model.SurveyId" class="btn btn-outline-primary">
        Back to questions
    </a>
    <a asp-action="Index" class="btn btn-outline-secondary">
        Back to surveys
    </a>
</div>
