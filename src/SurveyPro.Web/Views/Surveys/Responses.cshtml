@model SurveyPro.Web.ViewModels.Surveys.SurveyResponsesViewModel

@{
    ViewData["Title"] = "Survey Responses";
}

@section Styles {
    <link rel="stylesheet" href="~/css/surveys/responses.css" asp-append-version="true" />
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <h1 class="mb-1">@Model.SurveyTitle</h1>
        @if (!string.IsNullOrWhiteSpace(Model.SurveyDescription))
        {
            <p class="text-muted mb-0">@Model.SurveyDescription</p>
        }
    </div>

    <div class="d-flex gap-2 flex-wrap">
        @if (Model.Responses.Any())
        {
            <a asp-action="ExportResponsesPdf"
               asp-route-id="@Model.SurveyId"
               class="btn btn-danger">
                Export to PDF
            </a>

            <a asp-action="ExportResponsesCsv"
               asp-route-id="@Model.SurveyId"
               class="btn btn-success">
                Export to CSV
            </a>
        }
        @if (User.IsInRole("Author"))
        {
            <a asp-action="My" class="btn btn-outline-secondary">Back to my surveys</a>
        }
        else
        {
            <a asp-action="Index" class="btn btn-outline-secondary">Back to surveys</a>
        }
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-uppercase text-muted small">Submitted responses</div>
                <div class="display-6 fw-semibold">@Model.TotalSubmittedResponses</div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-uppercase text-muted small">Access code</div>
                @if (!string.IsNullOrWhiteSpace(Model.AccessCode))
                {
                    <div class="h4 mb-0"><code>@Model.AccessCode</code></div>
                }
                else
                {
                    <div class="text-muted">No active code</div>
                }
            </div>
        </div>
    </div>
</div>

@if (!Model.Responses.Any())
{
    <div class="alert alert-info">
        There are no submitted responses yet.
    </div>
}
else
{
    <div class="accordion" id="responsesAccordion">
        @for (var i = 0; i < Model.Responses.Count; i++)
        {
            var response = Model.Responses[i];
            var headingId = $"response-heading-{i}";
            var collapseId = $"response-collapse-{i}";

            <div class="accordion-item mb-2 border rounded-3 overflow-hidden">
                <h2 class="accordion-header" id="@headingId">
                    <button class="accordion-button @(i == 0 ? string.Empty : "collapsed")"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#@collapseId"
                            aria-expanded="@(i == 0 ? "true" : "false")"
                            aria-controls="@collapseId">
                        <div class="d-flex justify-content-between align-items-center w-100 me-3 flex-wrap gap-2">
                            <span class="fw-semibold">@response.RespondentName</span>
                            <span class="text-muted small">@response.RespondentEmail</span>
                            <span class="badge bg-secondary">
                                @response.SubmittedAt.ToLocalTime().ToString("g")
                            </span>
                        </div>
                    </button>
                </h2>

                <div id="@collapseId"
                     class="accordion-collapse collapse @(i == 0 ? "show" : string.Empty)"
                     aria-labelledby="@headingId"
                     data-bs-parent="#responsesAccordion">
                    <div class="accordion-body">
                        <div class="table-responsive">
                            <table class="table app-table table-sm table-hover align-middle mb-0" style="border-color: rgba(255, 255, 255, 0.15);">
                                <thead style="background: #0a1428 !important;">
                                    <tr>
                                        <th class="survey-responses-question-order" style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">#</th>
                                        <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Question</th>
                                        <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Type</th>
                                        <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Answer</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var answer in response.Answers.OrderBy(answer => answer.QuestionOrderNumber))
                                    {
                                        <tr>
                                            <td>@answer.QuestionOrderNumber</td>
                                            <td>@answer.QuestionText</td>
                                            <td><span class="badge bg-light text-dark">@answer.QuestionType</span></td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(answer.TextAnswer))
                                                {
                                                    <span>@answer.TextAnswer</span>
                                                }
                                                else if (answer.SelectedOptionTexts.Any())
                                                {
                                                    <span>@string.Join(", ", answer.SelectedOptionTexts)</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No answer</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (Model.Responses.Any())
{
    var questionGroups = Model.Responses
        .SelectMany(r => r.Answers)
        .GroupBy(a => new { a.QuestionId, a.QuestionText, a.QuestionType, a.QuestionOrderNumber })
        .OrderBy(g => g.Key.QuestionOrderNumber)
        .ToList();

    <div class="d-flex justify-content-between align-items-center mb-3 mt-5 flex-wrap gap-2">
        <h2 class="mb-0">Answer charts</h2>
        <div class="btn-group" role="group">
            <input type="radio" class="btn-check" name="chartType" id="chartTypeChart" value="chart" checked>
            <label class="btn btn-outline-primary" for="chartTypeChart">Pie Chart</label>

            <input type="radio" class="btn-check" name="chartType" id="chartTypeHistogram" value="histogram">
            <label class="btn btn-outline-primary" for="chartTypeHistogram">Histogram</label>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var group in questionGroups)
        {
            <div class="col-md-6">
                <div class="card border-0 shadow-sm h-100 bg-light bg-opacity-25 survey-responses-chart-card"
                     data-question-id="@group.Key.QuestionId" data-question-type="@group.Key.QuestionType">
                    <div class="card-body">
                        <h6 class="mb-1 survey-responses-chart-label">
                            QUESTION @group.Key.QuestionOrderNumber
                        </h6>
                        <p class="fw-semibold mb-3 survey-responses-chart-question">@group.Key.QuestionText</p>

                        @{
                            var optionCounts = group
                            .Where(a => a.SelectedOptionTexts.Any())
                            .SelectMany(a => a.SelectedOptionTexts)
                            .GroupBy(t => t)
                            .Select(g => new { Label = g.Key, Count = g.Count() })
                            .OrderByDescending(x => x.Count)
                            .ToList();

                            var chartId = $"chart_{group.Key.QuestionId:N}";

                            var palette = new[]
                            {
                "#9585de", "#de8eae", "#f4845f", "#a78bfa",
                "#dea78e", "#add64d", "#f87171", "#60a5fa",
                "#ec4899", "#fb923c", "#8b5cf6", "#10b981"
                };

                            var labelsJson = System.Text.Json.JsonSerializer.Serialize(
                            optionCounts.Select(x => x.Label).ToArray());
                            var countsJson = System.Text.Json.JsonSerializer.Serialize(
                            optionCounts.Select(x => x.Count).ToArray());
                            var colorsJson = System.Text.Json.JsonSerializer.Serialize(
                            optionCounts.Select((_, i) => palette[i % palette.Length]).ToArray());
                        }

                        @if (group.Key.QuestionType == "Text")
                        {
                            <div class="d-flex align-items-center justify-content-center text-light survey-responses-chart-empty survey-responses-chart-empty-dashed">
                                <span>Charts cannot be built for text answers</span>
                            </div>
                        }
                        else if (!optionCounts.Any())
                        {
                            <div class="d-flex align-items-center justify-content-center text-light survey-responses-chart-empty">
                                No answers yet
                            </div>
                        }
                        else
                        {
                            <div class="survey-responses-chart-wrapper">
                                <canvas id="@chartId"
                                        class="question-chart"
                                        data-labels="@labelsJson"
                                        data-counts="@countsJson"
                                        data-colors="@colorsJson"></canvas>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    @if (Model.Responses.Any())
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
        <script src="~/js/surveys/responses.js" asp-append-version="true"></script>
    }
}