@using SurveyPro.Application.DTOs.Surveys
@model IReadOnlyCollection<SurveyListItemDto>

@{
    ViewData["Title"] = "Surveys";
}

<h1 class="mb-3">Surveys</h1>

<form asp-controller="Participation" asp-action="Join" method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Join by access code</label>
            <input type="text" name="code" class="form-control" placeholder="Enter survey code" />
        </div>
        <div class="col-md-auto">
            <button type="submit" class="btn btn-primary">Open survey</button>
        </div>
    </div>
</form>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.Any())
{
    <p>There are currently no available surveys.</p>
}
else
{
    <table class="table app-table table-striped app-table-surveys">
        <thead class="app-table-header">
            <tr>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Title</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Description</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Status</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Created</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important; padding: 1rem; border: none;">Actions</th>
            </tr>
        </thead>
    
        <tbody>
            @foreach (var survey in Model)
            {
                <tr>
                    <td class="fw-semibold">
                        @survey.Title
                    </td>
    
                    <td>
                        @if (!string.IsNullOrWhiteSpace(survey.Description))
                        {
                            @survey.Description
                        }
                        else
                        {
                            <span class="text-muted-soft">
                                No description
                            </span>
                        }
                    </td>
    
                    <td>
                        <span class="badge text-bg-success">
                            @survey.Status
                        </span>
                    </td>
    
                    <td>
                        @survey.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </td>
    
                    <td>
                        <div class="d-flex gap-2 flex-wrap">
    
                            @if (!string.IsNullOrWhiteSpace(survey.AccessCode))
                            {
                                <a asp-controller="Participation"
                                   asp-action="Join"
                                   asp-route-code="@survey.AccessCode"
                                   class="btn-app-outline btn-sm text-decoration-none">
                                    Start survey
                                </a>
                            }
    
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Surveys"
                                   asp-action="Responses"
                                   asp-route-id="@survey.Id"
                                   class="btn-app-outline btn-sm text-decoration-none">
                                    View responses
                                </a>
                            }
    
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
