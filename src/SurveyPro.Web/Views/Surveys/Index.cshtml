@using SurveyPro.Application.DTOs.Surveys
@model IReadOnlyCollection<SurveyListItemDto>

@{
    ViewData["Title"] = "Surveys";
}

<h1 class="mb-3">Available Surveys</h1>

<form asp-controller="Participation" asp-action="Join" method="get" class="mb-4">
    <div class="row g-2 align-items-end">
        <div class="col-md-6">
            <label class="form-label">Join by access code</label>
            <input type="text" name="code" class="form-control" placeholder="Enter survey code" />
        </div>
        <div class="col-md-auto">
            <button type="submit" class="btn btn-primary">Open survey</button>
        </div>
    </div>
</form>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.Any())
{
    <p>There are currently no available surveys.</p>
}
else
{
    <div class="list-group">
        @foreach (var survey in Model)
        {
            <div class="list-group-item">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">@survey.Title</h5>
                    <small>@survey.CreatedAt.ToLocalTime().ToString("g")</small>
                </div>
                @if (!string.IsNullOrWhiteSpace(survey.Description))
                {
                    <p class="mb-1">@survey.Description</p>
                }
                <div class="d-flex justify-content-between align-items-center mt-2 flex-wrap gap-2">
                    <small>Статус: @survey.Status</small>

                    @if (!string.IsNullOrWhiteSpace(survey.AccessCode))
                    {
                        <a asp-controller="Participation" asp-action="Join" asp-route-code="@survey.AccessCode"
                           class="btn btn-outline-primary btn-sm">
                            Start survey
                        </a>
                    }
                </div>
            </div>
        }
    </div>
}
