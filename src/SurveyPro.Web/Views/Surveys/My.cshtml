@using SurveyPro.Application.DTOs.Surveys
@using SurveyPro.Domain.Enums
@model IReadOnlyCollection<SurveyListItemDto>

@{
    ViewData["Title"] = "My Surveys";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">My Surveys</h1>
    <a asp-action="Create" class="btn btn-primary">+ Create Survey</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.Any())
{
    <p>You don't have any surveys yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Public</th>
                <th>Invite Code</th>
                <th>Created</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var survey in Model)
            {
                <tr>
                    <td>@survey.Title</td>
                    <td>@survey.Status</td>
                    <td>@(survey.IsPublic ? "Yes" : "No")</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(survey.AccessCode))
                        {
                            <code>@survey.AccessCode</code>
                        }
                        else
                        {
                            <span class="text-muted">Pending</span>
                        }
                    </td>
                    <td>@survey.CreatedAt.ToLocalTime().ToString("g")</td>

                    <td>
                        <div style="display:flex; gap:8px; align-items:center;">
                    
                            @if (survey.Status != SurveyStatuses.Published)
                            {
                                <form asp-action="Publish" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@survey.Id" />
                                    <button type="submit" class="btn btn-success btn-sm">
                                        Publish
                                    </button>
                                </form>

                                <a asp-action="Edit" asp-route-id="@survey.Id" class="btn btn-primary btn-sm">
                                    Edit
                                </a>
                            }
                            else
                            {
                                <span class="text-success">Published</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(survey.AccessCode))
                            {
                                <a asp-controller="Participation" asp-action="Join" asp-route-code="@survey.AccessCode"
                                   class="btn btn-outline-success btn-sm">
                                    Respondent link
                                </a>
                            }


                            <!-- DELETE -->
                            <form asp-action="Delete" method="post" style="display:inline;">
                                <input type="hidden" name="id" value="@survey.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">
                                    Delete
                                </button>
                            </form>
                    
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}