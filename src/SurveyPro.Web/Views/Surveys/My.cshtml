@using SurveyPro.Application.DTOs.Surveys
@using SurveyPro.Domain.Enums
@model IReadOnlyCollection<SurveyListItemDto>

@{
    ViewData["Title"] = "My Surveys";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">My Surveys</h1>
    <a asp-action="Create" class="btn btn-primary">+ Create Survey</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!Model.Any())
{
    <p>You don't have any surveys yet.</p>
}
else
{
    <table class="table app-table table-striped" style="background: rgba(55, 75, 130, 0.5); border-color: rgba(255, 255, 255, 0.2); box-shadow: 0 18px 30px rgba(0, 0, 0, 0.2);">
        <thead style="background: #0a1428 !important;">
            <tr>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important;">Name</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important;">Status</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important;">Public</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important;">Invite Code</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important;">Created</th>
                <th style="color: #ffffff; font-weight: 700; background: #0a1428 !important;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var survey in Model)
            {
                <tr style="background: rgba(100, 120, 180, 0.3); color: #eef4ff;">
                    <td style="color: #eef4ff; border-top: 1px solid rgba(255, 255, 255, 0.1);">@survey.Title</td>
                    <td style="color: #eef4ff; border-top: 1px solid rgba(255, 255, 255, 0.1);">@survey.Status</td>
                    <td style="color: #eef4ff; border-top: 1px solid rgba(255, 255, 255, 0.1);">@(survey.IsPublic ? "Yes" : "No")</td>
                    <td style="color: #eef4ff; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                        @if (!string.IsNullOrWhiteSpace(survey.AccessCode))
                        {
                            <code style="color: #ffb238; font-weight: 600;">@survey.AccessCode</code>
                        }
                        else
                        {
                            <span class="text-muted" style="color: rgba(255, 255, 255, 0.5);">Pending</span>
                        }
                    </td>
                    <td style="color: #eef4ff; border-top: 1px solid rgba(255, 255, 255, 0.1);">@survey.CreatedAt.ToLocalTime().ToString("g")</td>

                    <td style="color: #eef4ff; border-top: 1px solid rgba(255, 255, 255, 0.1);">
                        <div class="d-flex gap-2 align-items-center">
                    
                            @if (survey.Status != SurveyStatuses.Published)
                            {
                                <form asp-action="Publish" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@survey.Id" />
                                    <button type="submit" class="btn btn-success btn-sm">
                                        Publish
                                    </button>
                                </form>

                                <a asp-action="Edit" asp-route-id="@survey.Id" class="btn btn-primary btn-sm">
                                    Edit
                                </a>
                            }

                            @if (!string.IsNullOrWhiteSpace(survey.AccessCode))
                            {
                                <a asp-controller="Participation" asp-action="Join" asp-route-code="@survey.AccessCode"
                                   class="btn btn-outline-success btn-sm">
                                    Respondent link
                                </a>
                            }

                            <a asp-action="Responses" asp-route-id="@survey.Id" class="btn btn-outline-info btn-sm">
                                View responses
                            </a>


                            <!-- DELETE -->
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@survey.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">
                                    Delete
                                </button>
                            </form>
                    
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}